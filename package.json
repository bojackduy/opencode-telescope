{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@bojackduy/opencode-telescope",
  "version": "0.1.25",
  "description": "OpenCode TUI plugin for fuzzy and semantic search across local conversation history, session transcripts, and AI coding chats",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bojackduy/opencode-telescope.git"
  },
  "homepage": "https://bojackduy.github.io/opencode-telescope/",
  "bugs": {
    "url": "https://github.com/bojackduy/opencode-telescope/issues"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "telescope",
    "search",
    "session",
    "conversation",
    "conversation-search",
    "semantic-search",
    "vector-search",
    "embeddings",
    "sqlite-vec",
    "history",
    "ai-chat-history",
    "llm-history",
    "fuzzy",
    "fuzzy-finder",
    "grep",
    "finder",
    "opencode-tui",
    "neovim",
    "chat-history"
  ],
  "scripts": {
    "typecheck": "bun tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "prepack": "bun run typecheck && bun test",
    "release:patch": "bun run typecheck && bun test && npm version patch -m \"chore: release %s\" && git push && git push origin $(git describe --tags --abbrev=0)",
    "release:minor": "bun run typecheck && bun test && npm version minor -m \"chore: release %s\" && git push && git push origin $(git describe --tags --abbrev=0)",
    "release:major": "bun run typecheck && bun test && npm version major -m \"chore: release %s\" && git push && git push origin $(git describe --tags --abbrev=0)"
  },
  "files": [
    "assets",
    "docs/index.html",
    "docs/semantic-search.md",
    "README.md",
    "LICENSE",
    "tui.tsx",
    "telescope.tsx",
    "search.ts",
    "search",
    "components",
    "ui",
    "tsconfig.json"
  ],
  "exports": {
    ".": {
      "import": "./tui.tsx"
    },
    "./tui": {
      "import": "./tui.tsx"
    }
  },
  "dependencies": {
    "sqlite-vec": "^0.1.9"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.9",
    "@opentui/core": "^0.4.1",
    "@opentui/solid": "^0.4.1",
    "@types/bun": "^1.3.14",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3"
  }
}
